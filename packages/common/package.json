{
  "name": "@sp-api-sdk/common",
  "author": "Bertrand Marron <bertrand@bizon.solutions>",
  "description": "Selling Parner API common library",
  "version": "3.0.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "source": "./src/index.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "xo": "xo --cwd=../.. packages/common",
    "check:ts": "tsc --noEmit",
    "build": "tsup",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest"
  },
  "dependencies": {
    "@sp-api-sdk/auth": "workspace:*",
    "axios": "^1.18.0",
    "axios-logger": "^2.8.1",
    "axios-retry": "^4.5.0",
    "read-pkg-up": "^7.0.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@sp-api-sdk/jest": "workspace:*",
    "@sp-api-sdk/typescript-config": "workspace:*",
    "nock": "^14.0.15",
    "strip-ansi": "^7.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bizon/selling-partner-api-sdk.git",
    "directory": "packages/common"
  },
  "bugs": {
    "url": "https://github.com/bizon/selling-partner-api-sdk/issues"
  },
  "homepage": "https://github.com/bizon/selling-partner-api-sdk/tree/master/packages/auth",
  "keywords": [
    "bizon",
    "amazon",
    "spa sdk",
    "sp api",
    "mws",
    "selling partner api",
    "marketplace webservice"
  ]
}
