{
  "name": "@sp-api-sdk/auth",
  "author": "Bertrand Marron <bertrand@bizon.solutions>",
  "description": "Login with Amazon (LWA) authentication for the Amazon Selling Partner API (SP-API)",
  "version": "3.1.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "source": "./src/index.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "xo": "xo --cwd=../.. packages/auth",
    "check:ts": "tsc --noEmit",
    "build": "tsdown",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "read-pkg-up": "^7.0.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@sp-api-sdk/jest": "workspace:*",
    "@sp-api-sdk/typescript-config": "workspace:*",
    "nock": "^14.0.16",
    "type-fest": "^5.8.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bizon/selling-partner-api-sdk.git",
    "directory": "packages/auth"
  },
  "bugs": {
    "url": "https://github.com/bizon/selling-partner-api-sdk/issues"
  },
  "homepage": "https://github.com/bizon/selling-partner-api-sdk/tree/master/packages/auth",
  "keywords": [
    "amazon",
    "amazon-sp-api",
    "auth",
    "bizon",
    "esm",
    "lwa",
    "nodejs",
    "sdk",
    "selling partner api",
    "selling-partner-api",
    "sp api",
    "sp sdk",
    "sp-api",
    "typescript"
  ]
}
